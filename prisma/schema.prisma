// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Users {
  id_user    Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  last_name  String?   @db.VarChar(100)
  birth_date DateTime?
  email      String    @db.VarChar(100)
  phone      String?   @db.VarChar(20)
  password   String    @db.VarChar(100)

  // relations
  sessions      Sessions[]
  user_mission  User_Missions[]

  @@map("Users")
}

model Organization {
  id_organisasi Int     @id @default(autoincrement())
  name          String  @db.VarChar(100)
  email         String  @db.VarChar(100)
  password      String  @db.VarChar(100)
  desc          String? @db.Text

  missions  Missions[]
  articles  Articles[]
  quizzes   Quizzes[]

  @@map("Organization")
}

model Quizzes {
  id_quiz       Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  category      String?   @db.VarChar(100)  // Harian, Mingguan, Bulanan
  total_points  Int?      @default(0)
  id_creator    Int
  created_at    DateTime? @default(now())

  creator   Organization @relation(fields: [id_creator], references: [id_organisasi])
  questions Questions[]

  @@map("Quizzes")
}

model Questions {
  id_question Int      @id @default(autoincrement())
  id_quiz     Int
  content     String   @db.Text
  points      Int?     @default(10)
  order       Int?     // Urutan pertanyaan

  quiz    Quizzes   @relation(fields: [id_quiz], references: [id_quiz], onDelete: Cascade)
  answers Answers[]

  @@map("Questions")
}

model Answers {
  id_answer   Int      @id @default(autoincrement())
  id_question Int
  content     String   @db.Text
  is_correct  Boolean  @default(false)

  question Questions @relation(fields: [id_question], references: [id_question], onDelete: Cascade)
  sessions Sessions[]

  @@map("Answers")
}

model Sessions {
  id_session   Int      @id @default(autoincrement())
  start_time   DateTime?
  end_time     DateTime?
  total_points Int?

  id_user   Int
  id_answer Int

  user   Users   @relation(fields: [id_user], references: [id_user])
  answer Answers @relation(fields: [id_answer], references: [id_answer])

  @@map("Sessions")
}

model Missions {
  id_mission    Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  tags          String?  @db.VarChar(255)
  desc          String?  @db.Text
  cover_image   String?  @db.VarChar(255)
  photo_caption String?  @db.VarChar(255)
  author_name   String?  @db.VarChar(100)
  author_role   String?  @db.VarChar(50)
  points        Int?
  highlights    String?  @db.Text
  date_created  DateTime? @default(now())
  id_creator    Int      // FK ke Organization.id_organisasi

  creator      Organization  @relation(fields: [id_creator], references: [id_organisasi])
  user_mission User_Missions[]

  @@map("Missions")
}

model User_Missions {
  id_working     Int      @id @default(autoincrement())
  id_user        Int
  id_mission     Int
  status         String?  @db.VarChar(100)
  points         Int?
  completed_time DateTime?

  user    Users    @relation(fields: [id_user], references: [id_user])
  mission Missions @relation(fields: [id_mission], references: [id_mission])

  @@map("User_Missions")
}

model Articles {
  id_article    Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  topic         String?  @db.VarChar(100)
  description   String?  @db.Text
  content       String?  @db.Text
  cover_image   String?  @db.VarChar(255)
  photo_caption String?  @db.VarChar(255)
  photo_credit  String?  @db.VarChar(100)
  author_name   String?  @db.VarChar(100)
  author_role   String?  @db.VarChar(50)
  place         String?  @db.VarChar(100)
  highlights    String?  @db.Text
  date_created  DateTime? @default(now())
  id_author     Int      // FK ke Organization.id_organisasi

  author Organization @relation(fields: [id_author], references: [id_organisasi])

  @@map("Articles")
}
